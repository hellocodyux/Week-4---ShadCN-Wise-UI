{
  "$schema": "https://json.schemastore.org/style-dictionary.json",
  "name": "Wise UI — Dark",
  "description": "Semantic tokens for Wise UI (dark mode). Values reference primitives; some are defined as alpha overlays for readable dark surfaces.",
  "semantic": {
    "color": {
      "background": {
        "screen": { "value": "{color.grey.600}" },
        "surface": { "value": "{color.grey.500}" },
        "surface2": { "value": "{color.grey.500}" },
        "subtle": { "value": "{color.grey.500}" },
        "accentWash": { "value": "rgba(159, 232, 112, 0.14)" }
      },
      "content": {
        "primary": { "value": "{color.grey.100}" },
        "secondary": { "value": "{color.grey.300}" },
        "tertiary": { "value": "{color.grey.400}" }
      },
      "border": {
        "default": { "value": "{color.grey.500}" }
      },
      "interactive": {
        "primary": { "value": "{color.product.interactive.accent}" },
        "primaryText": { "value": "{color.brand.green.700}" },
        "secondaryText": { "value": "{color.brand.green.500}" }
      },
      "sentiment": {
        "negative": { "value": "{color.product.sentiment.negative}" },
        "positive": { "value": "{color.brand.brightGreen}" },
        "warning": { "value": "{color.secondary.brightYellow}" }
      },
      "chart": {
        "1": { "value": "{color.secondary.brightOrange}" },
        "2": { "value": "{color.secondary.brightBlue}" },
        "3": { "value": "{color.secondary.brightYellow}" },
        "4": { "value": "{color.secondary.brightPink}" },
        "5": { "value": "{color.secondary.darkPurple}" }
      }
    }
  }
}

